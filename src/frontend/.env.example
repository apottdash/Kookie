# WedBridge Frontend — Environment Variables
# Copy this file to .env.local and fill in your Supabase credentials.
# Without these, the app falls back gracefully to sample/mock data.

# Supabase project URL — from your Supabase dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key — safe to expose in browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here
